{
  "kind": "collectionType",
  "collectionName": "unit_progresses",
  "info": {
    "singularName": "unit-progress",
    "pluralName": "unit-progresses",
    "displayName": "Unit Progress"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "state": {
      "type": "enumeration",
      "enum": [
        "locked, unlocked, in_progress, completed"
      ]
    },
    "order": {
      "type": "integer"
    },
    "completed_at": {
      "type": "datetime"
    },
    "enrollment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::enrollment.enrollment",
      "inversedBy": "unit_progresses"
    },
    "module": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::module.module",
      "inversedBy": "unit_progresses"
    }
  }
}
