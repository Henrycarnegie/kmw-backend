{
  "kind": "collectionType",
  "collectionName": "subscrition_plans",
  "info": {
    "singularName": "subscrition-plan",
    "pluralName": "subscrition-plans",
    "displayName": "subscription_plans"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true
    },
    "accessLevel": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "FREE_USER",
        "LOW",
        "PREMIUM"
      ]
    },
    "Price": {
      "type": "decimal",
      "required": true
    },
    "Duration": {
      "type": "integer",
      "required": true
    },
    "discountPercentage": {
      "type": "integer"
    },
    "stripePriceId": {
      "type": "string"
    },
    "stripeRenewalCouponId": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "memberships": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::membership.membership"
    }
  }
}
