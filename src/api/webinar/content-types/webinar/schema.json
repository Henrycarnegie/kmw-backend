{
  "kind": "collectionType",
  "collectionName": "webinars",
  "info": {
    "singularName": "webinar",
    "pluralName": "webinars",
    "displayName": "Webinar"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "scheduled_at": {
      "type": "datetime"
    },
    "recording_url": {
      "type": "string"
    },
    "meeting_url": {
      "type": "string"
    },
    "tier": {
      "type": "enumeration",
      "required": true,
      "default": "free",
      "enum": [
        "free",
        "lowcost",
        "premium"
      ]
    },
    "price": {
      "type": "decimal"
    },
    "max_capacity": {
      "type": "integer"
    },
    "waitlist_enabled": {
      "type": "boolean",
      "default": false
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "instructor_information": {
      "type": "text"
    },
    "duration_in_minutes": {
      "type": "integer"
    },
    "related_links": {
      "type": "string"
    },
    "webinar_registrations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::webinar-registration.webinar-registration",
      "mappedBy": "webinar"
    }
  }
}
