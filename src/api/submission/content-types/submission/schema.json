{
  "kind": "collectionType",
  "collectionName": "submissions",
  "info": {
    "singularName": "submission",
    "pluralName": "submissions",
    "displayName": "Submission"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "text_answer": {
      "type": "text"
    },
    "submitted_link": {
      "type": "string"
    },
    "file": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "state": {
      "type": "enumeration",
      "enum": [
        "submitted, reviewed, approved"
      ]
    },
    "teacher_feedback": {
      "type": "text"
    },
    "learner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "submissions"
    },
    "module": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::module.module",
      "inversedBy": "submissions"
    },
    "submitted_at": {
      "type": "datetime"
    },
    "reviewed_at": {
      "type": "datetime"
    }
  }
}
