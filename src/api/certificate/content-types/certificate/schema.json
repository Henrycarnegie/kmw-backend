{
  "kind": "collectionType",
  "collectionName": "certificates",
  "info": {
    "singularName": "certificate",
    "pluralName": "certificates",
    "displayName": "Certificate"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "certificate_id": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "learner_name": {
      "type": "string",
      "required": true
    },
    "course_title": {
      "type": "string",
      "required": true
    },
    "issued_at": {
      "type": "datetime"
    },
    "state": {
      "type": "enumeration",
      "enum": [
        "issued, revoked"
      ]
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "certificates"
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "certificates"
    }
  }
}
