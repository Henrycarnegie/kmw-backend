{
  "kind": "collectionType",
  "collectionName": "subscription_plans",
  "info": {
    "singularName": "subscription-plan",
    "pluralName": "subscription-plans",
    "displayName": "[Subscription] - Plan"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "accessLevel": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "free_user",
        "low",
        "premium"
      ]
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "duration": {
      "type": "integer",
      "required": true
    },
    "stripePriceId": {
      "type": "string",
      "required": true
    },
    "stripeRenewalCouponId": {
      "type": "string"
    },
    "discountPercentage": {
      "type": "integer"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "memberships": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::membership.membership",
      "mappedBy": "subscription_plan"
    }
  }
}
