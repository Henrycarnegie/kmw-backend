{
  "kind": "collectionType",
  "collectionName": "payments",
  "info": {
    "singularName": "payment",
    "pluralName": "payments",
    "displayName": "[Payment] - Main"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "amount": {
      "type": "decimal",
      "required": true
    },
    "paymentStatus": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "paid",
        "failed"
      ]
    },
    "purchaseType": {
      "type": "enumeration",
      "enum": [
        "membership",
        "renewal",
        "course",
        "webinar",
        "donation"
      ]
    },
    "provider": {
      "type": "string"
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": [
        "stripe",
        "paypal",
        "line_pay",
        "bank_transfer"
      ]
    },
    "paymentDate": {
      "type": "datetime"
    },
    "transactionReference": {
      "type": "string"
    },
    "stripeSessionId": {
      "type": "string"
    },
    "stripeInvoiceId": {
      "type": "string"
    },
    "stripeEventId": {
      "type": "string"
    },
    "donorName": {
      "type": "string"
    },
    "donorEmail": {
      "type": "email"
    },
    "donorMessage": {
      "type": "text"
    },
    "membershipApplicationData": {
      "type": "json"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "payments"
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course"
    },
    "webinar": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::webinar.webinar"
    },
    "membership": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::membership.membership"
    }
  }
}
