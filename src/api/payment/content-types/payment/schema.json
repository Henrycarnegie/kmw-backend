{
  "kind": "collectionType",
  "collectionName": "payments",
  "info": {
    "singularName": "payment",
    "pluralName": "payments",
    "displayName": "Payment"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Amount": {
      "type": "decimal",
      "required": true
    },
    "paymentStatus": {
      "type": "enumeration",
      "required": false,
      "default": "pending",
      "enum": [
        "pending",
        "paid",
        "failed"
      ]
    },
    "membership": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::membership.membership",
      "inversedBy": "payments"
    }
  }
}
