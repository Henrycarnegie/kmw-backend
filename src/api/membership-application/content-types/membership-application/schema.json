{
  "kind": "collectionType",
  "collectionName": "membership_applications",
  "info": {
    "singularName": "membership-application",
    "pluralName": "membership-applications",
    "displayName": "[Membership] - Application"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "planId": {
      "type": "integer",
      "required": true
    },
    "fullName": {
      "type": "string",
      "required": true
    },
    "birthday": {
      "type": "date",
      "required": true
    },
    "idNumber": {
      "type": "string"
    },
    "gender": {
      "type": "string",
      "required": true
    },
    "positionTitle": {
      "type": "string",
      "required": true
    },
    "isUniversityStudent": {
      "type": "string",
      "required": true
    },
    "address": {
      "type": "text",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "lineId": {
      "type": "string",
      "required": true
    },
    "submittedAt": {
      "type": "datetime"
    },
    "rawAnswers": {
      "type": "json"
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
