{
  "kind": "collectionType",
  "collectionName": "memberships",
  "info": {
    "singularName": "membership",
    "pluralName": "memberships",
    "displayName": "[Membership] - Main"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "memberships"
    },
    "subscriptionStatus": {
      "type": "enumeration",
      "enum": [
        "pending_payment",
        "active",
        "past_due",
        "cancelled",
        "expired",
        "inactive"
      ]
    },
    "accessLevel": {
      "type": "enumeration",
      "enum": [
        "free_user",
        "low",
        "premium"
      ]
    },
    "startDate": {
      "type": "datetime",
      "required": true
    },
    "endDate": {
      "type": "datetime",
      "required": true
    },
    "stripeSubscriptionId": {
      "type": "string"
    },
    "stripeCustomerId": {
      "type": "string"
    },
    "googleFormSubmitted": {
      "type": "boolean",
      "default": false
    },
    "subscription_plan": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subscription-plan.subscription-plan",
      "inversedBy": "memberships"
    },
    "payments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::payment.payment"
    }
  }
}
