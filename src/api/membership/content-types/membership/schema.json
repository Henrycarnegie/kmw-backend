{
  "kind": "collectionType",
  "collectionName": "memberships",
  "info": {
    "singularName": "membership",
    "pluralName": "memberships",
    "displayName": "Membership"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "memberships"
    },
    "subscriptionStatus": {
      "type": "enumeration",
      "enum": [
        "pending_payment",
        "active",
        "inactive",
        "expired"
      ]
    },
    "StartDate": {
      "type": "datetime",
      "required": true
    },
    "endDate": {
      "type": "datetime",
      "required": true
    },
    "accessLevel": {
      "type": "enumeration",
      "enum": [
        "free_user",
        "member"
      ]
    },
    "subscrition_plans": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::subscrition-plan.subscrition-plan"
    },
    "payments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::payment.payment"
    },
    "membershipStatus": {
      "type": "enumeration",
      "enum": [
        "pending_form",
        "pending_payment",
        "pending_approval",
        "active",
        "rejected",
        "expired"
      ]
    }
  }
}
